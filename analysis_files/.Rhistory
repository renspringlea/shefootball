# Load packages
library(stringr)
# Set up variables
today_date <- substr(as.POSIXct(Sys.Date(),tz="ACST"),1,10)
# Import manually downloaded bank statements
lines_statement <- readLines("~/Downloads/Statement.txt")
# Import the CSV file that matches the bank statement descriptions to the account
df_match_key <- read.csv("~/Scheduled/budget/budget_v6/match_key.csv")
# Format the statements nicely
# Keep all lines with dollar values
lines_value <- which(str_detect(lines_statement,fixed("$")))
# Keep all lines immediately before dollar values (i.e. descriptions)
lines_description <- lines_value-1
# Format as data frame
# Note that, out of laziness, the date now refers to the date you're running
# this script, which could be up to 7 days out from the transaction itself
df_statement <- data.frame("value"=lines_statement[lines_value],
"description"=lines_statement[lines_description],
"date"=today_date)
df_statement$value <- str_replace_all(df_statement$value,fixed("$"),"")
df_statement$value <- str_replace_all(df_statement$value,fixed(","),"")
df_statement$value <- as.numeric(df_statement$value)
df_statement$account <- ""
df_statement <- df_statement[,c("value","account","description","date")]
# Assign accounts based on string matching
for (i in 1:nrow(df_statement)){
tmp_desc <- df_statement[i,"description"]
tmp_account <- df_match_key[which(str_detect(tmp_desc,df_match_key$description_string)),
"match_account"]
if(!length(tmp_account)==1){
# If no match OR if more than one string is matched,
# (in both cases the length of tmp_account does not equal 1)
# proceed to manual review
tmp_account <- "manual"
}
df_statement[i,"account"] <- tmp_account
}
# Sort so that delete, manual, and pay rows are on the top
df_statement_delete <- df_statement[which(df_statement$account=="delete"),]
df_statement_pay <- df_statement[which(df_statement$account=="pay"),]
df_statement_manual <- df_statement[which(df_statement$account=="manual"),]
df_statement_others <- df_statement[which(!df_statement$account %in% c("delete","pay","manual")),]
transactions_action <- rbind(df_statement_delete,
df_statement_pay,
df_statement_manual,
df_statement_others)
if(class(transactions_action$value)=="character"){
transactions_action$value <- gsub("$","",transactions_action$value,fixed=T)
transactions_action$value <- as.numeric(transactions_action$value)
}
# Output as transactions_action.csv for automated processing
write.csv(transactions_action,
"~/Scheduled/budget/budget_v6/transactions_action.csv",
row.names=F)
