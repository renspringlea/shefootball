xr_historical_usd_summary,
")")
#"\n",
#"- GBP to AUD = ",
#round(as.numeric(vec_xr_current_gbp$rates$AUD),2),
#" (",
#xr_historical_gbp_summary,
#")",
############################
### Summarise everything ###
############################
# Write summary of account positions, formatted for dashboard
budget_ascii <- r"{
# Budget
}"
account_positions <- account_positions[order(account_positions$account),]
#account_positions <- account_positions[order(-account_positions$value),]
account_positions$av_combined_for_dashboard <- paste0("* ",
account_positions$account,
" = ",
account_positions$value)
#account_positions_dashboard <- toString(account_positions$av_combined_for_dashboard)
account_positions_dashboard <- paste(account_positions$av_combined_for_dashboard,collapse="\n")
account_positions_dashboard_string <- paste0(budget_ascii,
account_positions_dashboard,
"\n",
"\n",
"Position = ",
position_theoretical,
" (stated above) and ",
position_actual,
" (actually in bank)",
"\n",
xr_string)
writeLines(account_positions_dashboard_string,
"~/Scheduled/budget/budget_v5/account_positions_dashboard.txt")
#########################
### Graph time series ###
#########################
df_ts <- read.csv("~/Scheduled/budget/budget_v5/time_series.csv")
df_ts_new <- data.frame("account"=account_positions$account,
"value"=account_positions$value,
"date"=today_date_c)
df_ts <- rbind(df_ts,
df_ts_new)
write.csv(df_ts,"~/Scheduled/budget/budget_v5/time_series.csv",row.names=F)
df_ts_g <- df_ts
df_ts_g$date_f <- as.Date(as.character(df_ts_g$date),format="%Y%m%d")
g_ts <- ggplot(aes(x=date_f,y=value,color=account),data=df_ts_g) +
geom_line() +
geom_point() +
scale_x_date(breaks=sort(unique(df_ts_g$date_f)),
limits=c(as.Date("2025-11-29"),NA),
date_labels="%m-%d",
name=NULL) +
scale_y_continuous(name=NULL,
limits=c(-500,NA),
breaks=seq(round(min(df_ts_g$value)/1000)*1000,
round(max(df_ts_g$value)/1000)*1000,
1000),
labels=label_currency()) +
scale_color_brewer(palette="Set3",name=NULL) +
geom_hline(yintercept=0,linetype="dashed",color="#ccc6c3") +
labs(title="Money") +
theme(legend.position = "bottom") +
guides(color=guide_legend(nrow=3,byrow=TRUE))
ggsave("~/Scheduled/budget/budget_v5/g_money.png",g_ts,width=8,height=5)
install.packages("traits","fwtraits")
install.packages("traits")
install.packages("traits", repos = c('https://ropensci.r-universe.dev', 'https://cloud.r-project.org'))
install.packages("fwtraits")
install.packages("BioWorldR")
install.packages("reptiledbr")
